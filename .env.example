# ── HackerOne API ────────────────────────────────────────────
H1_API_USERNAME=your_h1_username
H1_API_TOKEN=your_h1_api_token

# ── LLM ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
# Must include the provider prefix for litellm routing
CREWAI_MODEL=anthropic/claude-sonnet-4-20250514
CREWAI_TEMPERATURE=0.2
CREWAI_MAX_TOKENS=4096

# ── Pipeline tuning ──────────────────────────────────────────
# Ignore programmes paying less than this (USD)
H1_MIN_BOUNTY=500
# How many programmes to evaluate per selection run
H1_MAX_PROGRAMMES=10
# low | medium | high | critical
MIN_SEVERITY=medium
# Seconds between requests
SCAN_DELAY=0.5
# Days before the squad revisits a completed programme
REVISIT_HOLD_DAYS=30

# ── Paths ────────────────────────────────────────────────────
# Campaign reports and submission records
REPORTS_DIR=./reports
# sqlmap output (defaults to system temp dir if unset)
SQLMAP_OUTPUT_DIR=./sqlmap-output
# Nuclei templates directory
# Linux/macOS: ~/.local/nuclei-templates
# Windows:     %USERPROFILE%\.local\nuclei-templates
NUCLEI_TEMPLATES=~/.local/nuclei-templates
NUCLEI_RATE_LIMIT=10
# Subdomain wordlist — only needed for DNS brute-forcing
# Install SecLists: https://github.com/danielmiessler/SecLists
# Linux:   /usr/share/seclists/Discovery/DNS/subdomains-top1million-5000.txt
# Windows: C:\Tools\SecLists\Discovery\DNS\subdomains-top1million-5000.txt
RECON_WORDLIST=/usr/share/seclists/Discovery/DNS/subdomains-top1million-5000.txt

# ── Debug ────────────────────────────────────────────────────
VERBOSE=false
